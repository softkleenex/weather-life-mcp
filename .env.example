# Weather Life MCP 환경변수 설정
# 이 파일을 복사하여 .env 파일을 생성하고 실제 API 키를 입력하세요.

# ===========================================
# 공공데이터포털 API 키
# https://www.data.go.kr 에서 발급
# ===========================================

# 기상청 단기예보 API 키 (Decoding)
WEATHER_API_KEY=your_weather_api_key_here

# 에어코리아 대기오염정보 API 키 (Decoding)
AIR_QUALITY_API_KEY=your_air_quality_api_key_here

# ===========================================
# 서버 설정
# ===========================================

# 서버 호스트 (기본값: 0.0.0.0)
HOST=0.0.0.0

# 서버 포트 (기본값: 8000)
PORT=8000

# 디버그 모드 (기본값: false)
DEBUG=false

# ===========================================
# 기본 위치 설정 (선택사항)
# ===========================================

# 기본 위치 (nx, ny 격자 좌표)
# 서울시청 기준: nx=60, ny=127
DEFAULT_NX=60
DEFAULT_NY=127

# 기본 측정소명 (미세먼지)
DEFAULT_STATION=중구
